# Copy this file to ".env" and fill in your keys.

# Required for real generation — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Signs login sessions. Any long random string. (Has a dev default if omitted.)
SECRET_KEY=change-me-to-a-long-random-string

# Optional — enables real Paystack checkout. Without it, you can still "simulate"
# upgrades in-app to test plan limits. Get test keys at https://dashboard.paystack.com
PAYSTACK_SECRET_KEY=
